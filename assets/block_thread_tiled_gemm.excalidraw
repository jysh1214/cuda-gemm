        }
      ],
      "updated": 1774967418408,
      "link": null,
      "locked": false,
      "text": "Thread's Position in Tile A:\n\nEach thread in tile A computes (A_LOADS_PER_THREAD):\n(BLOCK_TILE_M * BLOCK_TILE_K) / BLOCK_THREADS\n\nfor i = 0 ~ A_LOADS_PER_THREAD\n        linear = i * BLOCK_THREADS + tid\n        tile_row = linear / BLOCK_TILE_K\n        tile_col = linear % BLOCK_TILE_K",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Thread's Position in Tile A:\n\nEach thread in tile A computes (A_LOADS_PER_THREAD):\n(BLOCK_TILE_M * BLOCK_TILE_K) / BLOCK_THREADS\n\nfor i = 0 ~ A_LOADS_PER_THREAD\n        linear = i * BLOCK_THREADS + tid\n        tile_row = linear / BLOCK_TILE_K\n        tile_col = linear % BLOCK_TILE_K",
      "autoResize": true,
      "lineHeight": 1.25
    },
