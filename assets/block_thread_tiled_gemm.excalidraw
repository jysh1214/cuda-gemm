      "updated": 1774967383641,
      "link": null,
      "locked": false,
      "text": "Thread's Position in Tile B:\n\nEach thread in tile B computes (B_LOADS_PER_THREAD):\n(BLOCK_TILE_K * BLOCK_TILE_N) / BLOCK_THREADS\n\nfor i = 0 ~ B_LOADS_PER_THREAD\n        linear = i * BLOCK_THREADS + tid\n        tile_row = linear / BLOCK_TILE_N\n        tile_col = linear % BLOCK_TILE_N",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Thread's Position in Tile B:\n\nEach thread in tile B computes (B_LOADS_PER_THREAD):\n(BLOCK_TILE_K * BLOCK_TILE_N) / BLOCK_THREADS\n\nfor i = 0 ~ B_LOADS_PER_THREAD\n        linear = i * BLOCK_THREADS + tid\n        tile_row = linear / BLOCK_TILE_N\n        tile_col = linear % BLOCK_TILE_N",
      "autoResize": true,
      "lineHeight": 1.25
    },
